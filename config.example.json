{
  "listen_addr": ":8080",
  "upstream_base_url": "https://api.openai.com",
  "upstream_api_key": "",
  "api_keys": {
    "sk-your-gateway-key-1": "tenant-a",
    "sk-your-gateway-key-2": "tenant-b"
  },
  "rate_limit_rps": 10,
  "log_level": "info",
  "read_timeout": "30s",
  "write_timeout": "120s",
  "max_retries": 2,
  "retry_base_delay": "500ms",
  "telemetry_enabled": true,
  "telemetry_path": "/metrics",
  "cache_enabled": false,
  "cache_ttl": "1h",
  "cache_max_entries": 10000,
  "guardrails_enabled": false,
  "pii_buffer_words": 5
}
